{
  "name": "codi-api-tester",
  "main": "worker.js",
  "compatibility_date": "2025-06-01",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    // All requests (including static assets) go through the worker so the
    // TESTER_PASSWORD basic-auth gate covers the whole app.
    "run_worker_first": true
  }
}
